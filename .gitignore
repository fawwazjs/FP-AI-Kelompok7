# ---------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12
*.jks
*.keystore

# ---------------------------
# Databases
# ---------------------------
heritageguard.db
*.db
*.sqlite3
*.sql.bak
*.dump

# ---------------------------
# Python
# ---------------------------
venv/
.venv/
env/
ENV/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
*.whl
pip-log.txt
pip-delete-this-directory.txt

# ---------------------------
# Node / Next.js
# ---------------------------
node_modules/
.next/
out/
.turbo/
.vercel/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json

# ---------------------------
# Temp & Upload Directories
# ---------------------------
temp_uploads/
temp_outputs/
backend/temp_uploads/
backend/temp_outputs/

# ---------------------------
# AI Model Weights & Artifacts
# ---------------------------
*.pt
*.pth
*.onnx
*.bin
*.h5
*.pkl
*.joblib
*.safetensors
models/*.bin
models/*.pt

# ---------------------------
# Test Reports & Coverage
# ---------------------------
backend_test_report.md
*_test_report.md
coverage/
htmlcov/
.coverage
*.cover
.pytest_cache/
.tox/

# ---------------------------
# Logs
# ---------------------------
*.log
logs/

# ---------------------------
# IDE & Editor
# ---------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
*.sublime-workspace
*.sublime-project

# ---------------------------
# Docker (local volumes)
# ---------------------------
docker-compose.override.yml

# ---------------------------
# OS Files
# ---------------------------
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
*.lnk
