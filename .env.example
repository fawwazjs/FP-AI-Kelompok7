DATABASE_URL=postgresql+psycopg://heritageguard:replace-with-local-password@localhost:5432/heritageguard
POSTGRES_USER=heritageguard
POSTGRES_PASSWORD=replace-with-local-password
POSTGRES_DB=heritageguard

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=false

STORAGE_DIR=/tmp/heritageguard
MAX_UPLOAD_BYTES=10485760
MAX_TEXT_CHARS=5000

RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
TRANSLATION_CACHE_ENABLED=true
TRANSLATION_CACHE_TTL_SECONDS=3600
TRANSLATION_CACHE_MAX_ITEMS=512
REDIS_URL=redis://localhost:6379/0
SECURITY_HEADERS_ENABLED=true

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-local-password
